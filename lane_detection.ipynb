    "## 13. Create Demo Video (Optional)\n",
    "\n",
    "Generate a simple test video with synthetic lane detection demonstration."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_demo_video(output_path='demo_video.mp4', num_frames=60):\n",
    "    \"\"\"Create a demo video with synthetic lane animation\"\"\"\n",
    "    width, height = 640, 480\n",
    "    fps = 15\n",
    "    \n",
    "    fourcc = cv2.VideoWriter_fourcc(*'mp4v')\n",
    "    out = cv2.VideoWriter(output_path, fourcc, fps, (width, height))\n",
    "    \n",
    "    print(f\"Creating demo video with {num_frames} frames...\")\n",
    "    \n",
    "    for frame_idx in range(num_frames):\n",
    "        # Create road background\n",
    "        frame = np.ones((height, width, 3), dtype=np.uint8) * 80\n",
    "        \n",
    "        # Animated lane parameters\n",
    "        center_x = width // 2 + int(20 * np.sin(frame_idx * 0.1))\n",
    "        lane_width = 60 + int(10 * np.sin(frame_idx * 0.05))\n",
    "        \n",
    "        # Draw lanes\n",
    "        for y in range(height):\n",
    "            progress = y / height\n",
    "            spacing = lane_width * (0.3 + 0.7 * progress)\n",
",
    "            left_x = int(center_x - spacing)\n",
    "            right_x = int(center_x + spacing)\n",
    "            \n",
    "            thickness = max(2, int(5 * progress))\n",
    "            \n",
    "            if 0 <= left_x < width:\n",
    "                cv2.line(frame, (left_x - thickness//2, y), \n",
    "                        (left_x + thickness//2, y), (200, 200, 180), thickness)\n",
    "            if 0 <= right_x < width:\n",
    "                cv2.line(frame, (right_x - thickness//2, y), \n",
    "                        (right_x + thickness//2, y), (200, 200, 180), thickness)\n",
    "        \n",
    "        # Add blur for realism\n",
    "        frame = cv2.GaussianBlur(frame, (3, 3), 0)\n",
    "        out.write(frame)\n",
    "    \n",
    "    out.release()\n",
    "    print(f\"Demo video saved to {output_path}\")\n",
    "    return output_path\n",
    "\n",
    "# Create demo video\n",
    "demo_video_path = create_demo_video('demo_video.mp4', num_frames=90)\n",
    "\n",
    "# Process the demo video with our model\n",
    "print(\"\\nProcessing demo video with lane detection...\")\n",
    "process_video(model, demo_video_path, 'output_video.mp4', DEVICE, post_processor)\n",
    "\n",
    "print(\"\\nDemo complete! Check output_video.mp4 for lane detection results.\")"
   ]
