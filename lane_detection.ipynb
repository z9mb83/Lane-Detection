   "source": [
    "def plot_training_history(history):\n",
    "    fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
    "    \n",
    "    epochs = range(1, len(history['train_loss']) + 1)\n",
    "    \n",
    "    # Loss\n",
    "    axes[0].plot(epochs, history['train_loss'], 'b-', label='Train Loss')\n",
    "    axes[0].plot(epochs, history['val_loss'], 'r-', label='Val Loss')\n",
    "    axes[0].set_xlabel('Epoch')\n",
    "    axes[0].set_ylabel('Loss')\n",
    "    axes[0].set_title('Training & Validation Loss')\n",
    "    axes[0].legend()\n",
    "    axes[0].grid(True, alpha=0.3)\n",
    "    \n",
    "    # IoU\n",
    "    axes[1].plot(epochs, history['train_iou'], 'b-', label='Train IoU')\n",
    "    axes[1].plot(epochs, history['val_iou'], 'r-', label='Val IoU')\n",
    "    axes[1].set_xlabel('Epoch')\n",
    "    axes[1].set_ylabel('IoU')\n",
    "    axes[1].set_title('Training & Validation IoU')\n",
    "    axes[1].legend()\n",
    "    axes[1].grid(True, alpha=0.3)\n",
    "    \n",
    "    # Accuracy\n",
    "    axes[2].plot(epochs, history['train_acc'], 'b-', label='Train Acc')\n",
    "    axes[2].plot(epochs, history['val_acc'], 'r-', label='Val Acc')\n",
    "    axes[2].set_xlabel('Epoch')\n",
    "    axes[2].set_ylabel('Accuracy')\n",
    "    axes[2].set_title('Training & Validation Accuracy')\n",
    "    axes[2].legend()\n",
    "    axes[2].grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig('training_curves.png', dpi=150, bbox_inches='tight')\n",
    "    plt.show()\n",
    "    print(\"Saved training curves to training_curves.png\")\n",
    "\n",
    "plot_training_history(history)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Post-Processing: Lane Detection with Polynomial Fitting"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class LanePostProcessor:\n",
    "    def __init__(self, min_points=10):\n",
    "        self.min_points = min_points\n",
    "    \n",
    "    def detect_lanes(self, mask, original_shape):\n",
    "        \"\"\"\n",
    "        Detect lane lines from binary mask and fit polynomials\n",
    "        Returns: dict with left and right lane coefficients\n",
    "        \"\"\"\n",
    "        # Resize mask to original shape\n",
    "        mask_resized = cv2.resize(mask.astype(np.uint8), \n",
    "                                   (original_shape[1], original_shape[0]))\n",
    "        \n",
    "        # Find contours\n",
    "        contours, _ = cv2.findContours(mask_resized, cv2.RETR_EXTERNAL, \n",
    "                                       cv2.CHAIN_APPROX_SIMPLE)\n",
    "        \n",
    "        lanes = {'left': None, 'right': None}\n",
    "        \n",
    "        if len(contours) >= 1:\n",
    "            # Get points from all contours\n",
    "            all_points = []\n",
    "            for cnt in contours:\n",
    "                if len(cnt) >= self.min_points:\n",
    "                    for point in cnt:\n",
    "                        all_points.append(point[0])\n",
    "            \n",
    "            if len(all_points) >= self.min_points:\n",
    "                all_points = np.array(all_points)\n",
    "                \n",
    "                # Split into left and right lanes based on x position\n",
    "                center_x = original_shape[1] // 2\n",
    "                left_points = all_points[all_points[:, 0] < center_x]\n",
    "                right_points = all_points[all_points[:, 0] >= center_x]\n",
    "                \n",
    "                # Fit polynomials\n",
    "                if len(left_points) >= self.min_points:\n",
    "                    lanes['left'] = np.polyfit(left_points[:, 1], left_points[:, 0], 2)\n",
    "                if len(right_points) >= self.min_points:\n",
    "                    lanes['right'] = np.polyfit(right_points[:, 1], right_points[:, 0], 2)\n",
    "        \n",
    "        return lanes\n",
    "    \n",
    "    def draw_lanes(self, image, lanes, color_left=(0, 255, 0), color_right=(0, 0, 255)):\n",
    "        \"\"\"Draw fitted lane lines on image\"\"\"\n",
    "        result = image.copy()\n",
    "        h, w = image.shape[:2]\n",
    "        \n",
    "        y_vals = np.linspace(h//2, h-1, 50, dtype=int)\n",
    "        \n",
    "        # Draw left lane\n",
    "        if lanes['left'] is not None:\n",
    "            left_x = np.polyval(lanes['left'], y_vals).astype(int)\n",
    "            left_points = np.column_stack((left_x, y_vals))\n",
    "            left_points = left_points[(left_points[:, 0] >= 0) & (left_points[:, 0] < w)]\n",
    "            if len(left_points) > 1:\n",
    "                cv2.polylines(result, [left_points], False, color_left, 8)\n",
    "        \n",
    "        # Draw right lane\n",
    "        if lanes['right'] is not None:\n",
    "            right_x = np.polyval(lanes['right'], y_vals).astype(int)\n",
    "            right_points = np.column_stack((right_x, y_vals))\n",
    "            right_points = right_points[(right_points[:, 0] >= 0) & (right_points[:, 0] < w)]\n",
    "            if len(right_points) > 1:\n",
    "                cv2.polylines(result, [right_points], False, color_right, 8)\n",
    "        \n",
    "        # Fill lane area if both lanes detected\n",
    "        if lanes['left'] is not None and lanes['right'] is not None:\n",
    "            left_x = np.polyval(lanes['left'], y_vals).astype(int)\n",
    "            right_x = np.polyval(lanes['right'], y_vals).astype(int)\n",
    "            \n",
    "            # Create polygon\n",
    "            pts_left = np.column_stack((left_x, y_vals))\n",
    "            pts_right = np.column_stack((right_x, y_vals))\n",
    "            pts_right = pts_right[::-1]  # Reverse for proper polygon\n",
    "            \n",
    "            pts = np.vstack((pts_left, pts_right))\n",
    "            pts = pts[(pts[:, 0] >= 0) & (pts[:, 0] < w)]\n",
    "            \n",
    "            if len(pts) >= 3:\n",
    "                overlay = result.copy()\n",
    "                cv2.fillPoly(overlay, [pts], (0, 255, 0))\n",
    "                result = cv2.addWeighted(result, 0.7, overlay, 0.3, 0)\n",
    "        \n",
    "        return result\n",
    "\n",
    "post_processor = LanePostProcessor()\n",
    "print(\"Post-processor ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 10. Inference Functions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def predict_image(model, image_path, device, post_processor=None):\n",
    "    \"\"\"\n",
    "    Run inference on a single image\n",
    "    Returns: original image, predicted mask, and overlayed result\n",
    "    \"\"\"\n",
    "    # Load image\n",
    "    image = cv2.imread(str(image_path))\n",
    "    image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n",
    "    original = image.copy()\n",
    "    h, w = image.shape[:2]\n",
    "    \n",
    "    # Preprocess\n",
    "    image_resized = cv2.resize(image, (384, 256))\n",
    "    image_norm = image_resized / 255.0\n",
    "    mean = np.array([0.485, 0.456, 0.406])\n",
    "    std = np.array([0.229, 0.224, 0.225])\n",
    "    image_norm = (image_norm - mean) / std\n",
    "    image_tensor = torch.from_numpy(image_norm.transpose(2, 0, 1)).float().unsqueeze(0)\n",
    "    \n",
    "    # Predict\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        image_tensor = image_tensor.to(device)\n",
    "        pred = model(image_tensor)\n",
    "        pred = torch.sigmoid(pred)\n",
    "        pred_mask = pred.squeeze().cpu().numpy()\n",
    "    \n",
    "    # Resize back to original size\n",
    "    pred_mask = cv2.resize(pred_mask, (w, h))\n",
    "    pred_binary = (pred_mask > 0.5).astype(np.uint8)\n",
    "    \n",
    "    # Post-process and draw lanes\n",
    "    if post_processor:\n",
    "        lanes = post_processor.detect_lanes(pred_binary, (h, w))\n",
    "        result = post_processor.draw_lanes(original, lanes)\n",
    "    else:\n",
    "        # Simple overlay\n",
    "        overlay = original.copy()\n",
    "        overlay[pred_binary > 0] = [0, 255, 0]\n",
    "        result = cv2.addWeighted(original, 0.7, overlay, 0.3, 0)\n",
    "    \n",
    "    return original, pred_mask, result\n",
    "\n",
    "def process_video(model, video_path, output_path, device, post_processor=None):\n",
    "    \"\"\"Process video and save output with lane detection\"\"\"\n",
    "    cap = cv2.VideoCapture(str(video_path))\n",
    "    \n",
    "    fps = int(cap.get(cv2.CAP_PROP_FPS))\n",
    "    width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n",
    "    height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n",
    "    \n",
    "    fourcc = cv2.VideoWriter_fourcc(*'mp4v')\n",
    "    out = cv2.VideoWriter(str(output_path), fourcc, fps, (width, height))\n",
    "    \n",
    "    frame_count = 0\n",
    "    total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n",
    "    \n",
    "    with tqdm(total=total_frames, desc=\"Processing video\") as pbar:\n",
    "        while True:\n",
    "            ret, frame = cap.read()\n",
    "            if not ret:\n",
    "                break\n",
    "            \n",
    "            # Convert to RGB for processing\n",
    "            frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)\n",
    "            \n",
    "            # Predict\n",
    "            _, _, result = predict_image(model, None, device, post_processor)\n",
    "            \n",
    "            # Manual prediction for video frames\n",
    "            h, w = frame.shape[:2]\n",
    "            frame_resized = cv2.resize(frame_rgb, (384, 256))\n",
    "            frame_norm = frame_resized / 255.0\n",
    "            mean = np.array([0.485, 0.456, 0.406])\n",
    "            std = np.array([0.229, 0.224, 0.225])\n",
    "            frame_norm = (frame_norm - mean) / std\n",
    "            frame_tensor = torch.from_numpy(frame_norm.transpose(2, 0, 1)).float().unsqueeze(0)\n",
    "            \n",
    "            model.eval()\n",
    "            with torch.no_grad():\n",
    "                frame_tensor = frame_tensor.to(device)\n",
    "                pred = model(frame_tensor)\n",
    "                pred = torch.sigmoid(pred)\n",
    "                pred_mask = pred.squeeze().cpu().numpy()\n",
    "            \n",
    "            pred_mask = cv2.resize(pred_mask, (w, h))\n",
    "            pred_binary = (pred_mask > 0.5).astype(np.uint8)\n",
    "            \n",
    "            if post_processor:\n",
    "                lanes = post_processor.detect_lanes(pred_binary, (h, w))\n",
    "                result = post_processor.draw_lanes(frame_rgb, lanes)\n",
    "            else:\n",
    "                overlay = frame_rgb.copy()\n",
    "                overlay[pred_binary > 0] = [0, 255, 0]\n",
    "                result = cv2.addWeighted(frame_rgb, 0.7, overlay, 0.3, 0)\n",
    "            \n",
    "            # Convert back to BGR for video writer\n",
    "            result_bgr = cv2.cvtColor(result, cv2.COLOR_RGB2BGR)\n",
    "            out.write(result_bgr)\n",
    "            \n",
    "            frame_count += 1\n",
    "            pbar.update(1)\n",
    "    \n",
    "    cap.release()\n",
    "    out.release()\n",
    "    print(f\"\\nVideo saved to {output_path}\")\n",
    "    print(f\"Processed {frame_count} frames\")\n",
    "\n",
    "print(\"Inference functions ready\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 11. Visualize Predictions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def visualize_predictions(model, dataset, num_samples=4, device='cpu'):\n",
    "    \"\"\"Visualize model predictions on validation samples\"\"\"\n",
    "    fig, axes = plt.subplots(3, num_samples, figsize=(16, 12))\n",
    "    \n",
    "    model.eval()\n",
    "    \n",
    "    for i in range(num_samples):\n",
    "        image, mask = dataset[i]\n",
    "        image_np = image.permute(1, 2, 0).numpy()\n",
    "        \n",
    "        # Denormalize\n",
    "        mean = np.array([0.485, 0.456, 0.406])\n",
    "        std = np.array([0.229, 0.224, 0.225])\n",
    "        image_np = std * image_np + mean\n",
    "        image_np = np.clip(image_np, 0, 1)\n",
    "        \n",
    "        # Predict\n",
    "        with torch.no_grad():\n",
    "            image_batch = image.unsqueeze(0).to(device)\n",
    "            pred = model(image_batch)\n",
    "            pred = torch.sigmoid(pred)\n",
    "            pred_np = pred.squeeze().cpu().numpy()\n",
    "        \n",
    "        mask_np = mask.squeeze().numpy()\n",
    "        \n",
    "        # Plot\n",
    "        axes[0, i].imshow(image_np)\n",
    "        axes[0, i].set_title(f\"Original {i+1}\")\n",
    "        axes[0, i].axis('off')\n",
    "        \n",
    "        axes[1, i].imshow(mask_np, cmap='gray')\n",
    "        axes[1, i].set_title(f\"Ground Truth {i+1}\")\n",
    "        axes[1, i].axis('off')\n",
    "        \n",
    "        axes[2, i].imshow(pred_np, cmap='gray')\n",
    "        axes[2, i].set_title(f\"Prediction {i+1}\")\n",
    "        axes[2, i].axis('off')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig('predictions_comparison.png', dpi=150, bbox_inches='tight')\n",
    "    plt.show()\n",
    "    print(\"Saved predictions comparison to predictions_comparison.png\")\n",
    "\n",
    "# Load best model for visualization\n",
    "checkpoint = torch.load('models/best_lane_model.pth', map_location=DEVICE)\n",
    "model.load_state_dict(checkpoint['model_state_dict'])\n",
    "print(f\"Loaded best model from epoch {checkpoint['epoch']+1} (IoU: {checkpoint['best_iou']:.4f})\")\n",
    "\n",
    "visualize_predictions(model, val_dataset, num_samples=4, device=DEVICE)"
   ]
  },
